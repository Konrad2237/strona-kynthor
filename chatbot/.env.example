# Klucz API Anthropic — ustaw w panelu Netlify (Site settings > Environment variables)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Claude
CLAUDE_MODEL=claude-sonnet-4-20250514

# Maksymalna liczba tokenów w odpowiedzi
MAX_TOKENS=1000

# Limit wiadomości na godzinę per IP
RATE_LIMIT=20

# Nazwa chatbota
BOT_NAME=Darnok
